	template <int N> class BitMask {  // параметризовать по типу?
		static const int sz = N/64+bool(N%64);
		uint64_t p[sz];  // счетчик с числом единиц?
		int count = 0;
	public:
		int size0() const { int res = 0; for(int i=0; i<sz; i++){ res += __builtin_popcountl(p[i]); } return res; }
		int size() const { return count; }
		void fill(bool x){
			if(x){
				for(int i=0; i<sz-bool(N%64); i++) p[i] = ~uint64_t(0);
				if(N%64) p[sz-1] = (uint64_t(1)<<N%64)-1;
			}
			else for(int i=0; i<sz; i++) p[i] = 0;
			count = x? N: 0;
		}
		BitMask(bool x=false){ fill(x); }
		BitMask(const BitMask &src, bool inv=false){
			if(inv){
				for(int i=0; i<sz-bool(N%64); i++) p[i] = ~src.p[i];
				if(N%64) p[sz-1] = ~src.p[sz-1]&((uint64_t(1)<<N%64)-1);
				count = N-src.count;
			} else { count = src.count;  for(int i=0; i<sz; i++) p[i] = src.p[i]; }
			// count = size0();
		}
		void swap(BitMask &other){ std::swap(p, other.p);  std::swap(count, other.count); }
		
		bool get(int i) const { return p[i/64]&(uint64_t(1)<<i%64); }
		bool operator [](int i) const { return get(i); }
		void set(int i, bool x=true){
			uint64_t mask = uint64_t(1)<<(i%64);
			if(x){ count += !bool(p[i/64]&mask); p[i/64] |=  mask; }
			else{  count -=  bool(p[i/64]&mask); p[i/64] &= ~mask; }
		}
		void insert(int i){ set(i); }           // as std::set<int> 
		void remove(int i){ set(i, false); }    // as std::set<int>
		bool any0() const {
			for(int i=0; i<sz; i++) if(p[i]) return true;
			return false;
		}
		bool any() const { return count; }
		operator bool () const { return any(); }
		bool operator !() const { return !any(); }
		bool all0() const {
			for(int i=0; i<sz-bool(N%64); i++) if(p[i]!=~uint64_t(0)) return false;
			if(N%64 && p[sz-1]!=(uint64_t(1)<<N%64)-1) return false;
			return true;			
		}
		bool all() const { return count==N; }
		BitMask operator ~ () const { return BitMask(*this, true); }  // ???

		class Iterator{
			friend class BitMask;
			const uint64_t *p = nullptr; int pos = N, sz = N;
		public:
			int operator * () const { return pos; }
			bool operator != (Iterator) const { return pos<sz; }
			void operator ++ (){  // это можно оптимизировать
				while(pos<N && *p && ++pos%64) if(*p&(uint64_t(1)<<pos%64)) return;
				while(pos<N && !*++p) pos += 64; 
				while(pos<N && !(*p&(uint64_t(1)<<pos%64))) pos++;
			}
		};
		Iterator begin() const {  // это можно оптимизировать
			Iterator I; I.p = p; I.pos = 0;
			for(int i=0; i<sz && !p[i]; i++){ I.p++; I.pos += 64; }
			while(I.pos<N && !get(I.pos)) I.pos++;
			return I;
		}
		Iterator end() const { return Iterator(); }
		// __builtin_ffsl (unsigned long x)
		// Возвращает единицу плюс индекс младшего значащего 1 бита x, или, если x равно нулю, возвращает ноль. 

		BitMask& operator |= (const BitMask &other){
			for(int i=0; i<sz; i++) p[i] |= other.p[i];
			count = size0();
			return *this;
		}
		BitMask& operator &= (const BitMask &other){
			for(int i=0; i<sz; i++) p[i] &= other.p[i];
			count = size0(); 
			return *this;
		}
		// bool chunk(int i, uint64_t mask, bool on) const { return ((p[i/64]>>(i%64))&mask)==mask*on; }
		bool chunk(const int D, int i, bool on=true) const { uint64_t m = (~uint64_t(0))>>(64-(1<<D));  return ((p[i/64]>>(i%64))&m)==m*on; }
		// добавить срезы?
		// operator ~ ?
	};
