	protected:  
		struct BItem: public Item {
		protected:
			friend class TiledAdaptiveMesh;
			using Item::storage;
			using Item::tile;
			using Item::cube;
			using Item::toff_cube;
			using Item::tpos;
			using Item::snodes;
			using Item::stencil_sz;
			using Item::off;
		public:
			using Item::srank;
			const T* operator [] (int cID) noexcept;  ///< доступ к элементу шаблона номер cID, если такого узла нет возвращает nullptr
			uint64_t bmask(bool out_border) const;    ///< возвращает маску с информацией о расположении соседей по шаблону за границей сетки или границей разбиения
		};
		//-------  скрытые поля  -----------
		Ind<D> tbox;     ///< размер сетки в тайлах нулевого ранга разбиения
		Ind<D> tmul;     ///< множитель расчета смещения на основе позиции на сетке тайлов нулевого ранга
		int zbound;      ///< 64-log2(tbox.prod()) --- граница в ключе (toff) отделяющая смещение по сетке нулевого ранга от Z-кривой
		int rank_lim;    ///< максимально возможный ранг разбиения сетки
		uint64_t zmask;  ///< (1<<zbound)-1, в ключе 59 bit offset,  5 bit rank, offset максимально прижат влево
		static const uint32_t dbits = (1<<D)-1;
		uint32_t bmask[calc_3pow<D>::x];  ///< куб 3x3... для  Item::out_border_mask() позволяющий определять выход tID за границу сетки, 2 бита на ось кодируют tID в кубе

		//-------  функции для работы с ключами и позициями тайлов  -----------
		uint64_t tpos2toff(Ind<D> tpos, int rank) const;  ///< пересчитывает позицию и ранг тайла в ключ forest, в т.ч. реализует ПГУ
		Ind<D> toff2tpos(uint64_t toff) const { int r = toff&31; return (toff>>zbound)%tbox*(1<<r) + *ZCurve64<D>((toff&zmask)>>(zbound-D*r), r); }  ///< вычисляет позицию тайла

		uint64_t next_toff(uint64_t toff) const { return toff+(uint64_t(1)<<(zbound-(toff&31)*D))-(toff&31); }   ///< следующий тайл на том же ранге
		// uint64_t up_toff(uint64_t toff) const { int r = toff&31; return (toff&~((uint64_t(1)<<(zbound-(r-1)*D))-1)) | (r-1); }  ///< тайл сверху !!! не проверяет rank>0 !!!
		uint64_t up_toff(uint64_t toff) const { int r = (toff&31)-1; return (toff&~(zmask>>r*D))|r; }  ///< тайл сверху !!! не проверяет rank>0 !!!

		//  up_chID нигде кроме up_off не используется?
		int up_chID(uint64_t toff) const { return (toff>>(zbound-(toff&31)*D))&dbits; }  ///< позиция тайла toff в тайле сверху !!! не проверяет rank>0 !!!
		int up_off(uint64_t toff, int off) const { return (up_chID(toff)<<((R-1)*D))|(off>>D); }  ///< позиция УЗЛА off из тайла toff в тайле сверху

		bool dec_rank(uint64_t &toff, int &off) const {  ///< уменьшает (по возможности) ранг тайла и согласованно изменяет off и toff
			if((toff&31)==0 || (!cell_based && (off&dbits))) return false;
			off = up_off(toff, off);  toff = up_toff(toff);
			return true;
		}
		bool inc_rank(uint64_t &toff, int &off) const {  ///< увеличивает (по возможности) ранг тайла и согласованно изменяет off и toff
			if((toff&31)>=rank_lim) return false;
			toff++;  toff |= uint64_t(off>>(R-1)*D)<<(zbound-(toff&31)*D);  off = (off<<D)&((1<<(R*D))-1);
			return true;
		}
		//-----------------  основная структура данных  ------------------------  
		std::map<uint64_t, tile_t> forest;          ///< хранилище тайлов обеспечивающее быстрый доступ при необходимости
		std::vector<tile_t*> tiles;                 ///< таблица указателей на тайлы для параллельного обхода
		std::vector<std::vector<tile_t*> > rtiles;  ///< таблица указателей на тайлы по рангам

		tile_t& add_tile(const Ind<D> &tpos, const int rank);  ///< при необходимости добавляет тайл и встраивает его в струкутуру данных
		void del_tile(int tID);
		
		Ind<D> coords[1<<R*D];              ///< позиции по Z-кривой в тайле
		std::vector<std::vector<stencil_node_t> > stencils;   // для каждого шаблона хранится stencil_sz вариантов по 1<<R*D элементов

		bool fix_mode;  ///< задает стадию обхода для Item

		bool config_item(BItem& item, tile_t* tile);  ///< конфигурирует Item, возвращает принадлежность к границе разбиения
		template <typename Func> void rebuild(Func func, BItem* items, int items_sz);  ///< завершает перестроение сетки
		struct item_addr_t{  ///< для for_zorder
			uint64_t zoff;
			int32_t tID, off;
			item_addr_t(uint64_t zoff_, int32_t tID_, int32_t off_): zoff(zoff_), tID(tID_), off(off_){}
			bool operator < (const item_addr_t& other) const { return zoff<other.zoff; }
		};

		// эту функцию можно соптимизировать если известен итератор на тайл?
		bool check_children(uint64_t toff, int off, const tile_t* tile=nullptr) const;  ///< проверяет наличие потомка на один уровень вниз, tile позволяет иcключить forest.find
		bool check_parent(uint64_t &toff, int &off, tile_t** tile);  ///< проверяет наличие родителя на один уровень вверх, в случае успеха настраивает аргументы на родителя		
		
		struct grad_patch_t{ typename Item::patch_t *ipp; std::set<int> table; };
		void split_item(BItem& item, uint64_t toff, int off, tile_t *tile, std::unordered_map<uint64_t, grad_patch_t> &table); 
